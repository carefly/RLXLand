Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: None
  Suppress:
    - "-Wmicrosoft-enum-forward-reference"
    - "-Wc++11-narrowing"
    - "-Wc++2b-extensions"
    - "-Wmicrosoft-cast"
CompileFlags:
  Add:
    - "-ferror-limit=0"
    - '-D__FUNCTION__="dummy"'
    - '-D__clangd__'
    - "-Isrc"
    - "-DRLX_MONEY_ENABLED"
    - "-DNOMINMAX"
    - "-DUNICODE"
    - "-std=c++20"